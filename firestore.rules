rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function validBirthDate() {
      return request.resource.data.birthDate is string
        && request.resource.data.birthDate.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
    }

    function validAppointmentDate() {
      return request.resource.data.appointmentDate is string
        && request.resource.data.appointmentDate.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
    }

    match /reservations/{reservationId} {
      allow create: if request.resource.data.fullName is string
        && request.resource.data.fullName.size() >= 4
        && validBirthDate()
        && request.resource.data.email is string
        && request.resource.data.phone is string
        && request.resource.data.product is string
        && request.resource.data.product.size() > 0
        && request.resource.data.interest is string
        && request.resource.data.interest.size() > 0
        && validAppointmentDate()
        && request.resource.data.appointmentType is string
        && request.resource.data.appointmentType.size() > 0
        && request.resource.data.privacyAccepted == true
        && request.resource.data.status is string
        && request.resource.data.crmStage is string
        && request.resource.data.source is string;

      allow read, update, delete: if isSignedIn();
    }
  }
}
